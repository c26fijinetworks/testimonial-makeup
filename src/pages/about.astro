---
import Hero from '~/components/widgets/Hero.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = {
  title: 'Our Mission - Testimonial Makeup | Built for Stylists',
  description: 'We built Testimonial Makeup because hair is art, but business is about trust. Learn how we help salon owners dominate Google without the monthly fees.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
<Hero2
    tagline="We Grow Your Salon ⭐⭐⭐⭐⭐"
    title='You Create the Art.<br/><span class="text-accent dark:text-white">We Help You Build Your Reputation.</span>'
    subtitle="Amazing stylists lose clients without reviews. We ensure your reputation matches your talent. No monthly fees—just a simple, automated system to keep your books full."
    video="/images/hero-animation.mp4" 
    poster="/images/hero-poster.webp"
    actions={[
      { variant: 'primary', text: 'Claim My Lifetime Access - $99', href: '/pricing/' },
    ]}
  />
  <!-- Content 1: The "Why" -->
  <Content
    isReversed
    items={[
        { title: 'The "Mirror Reveal" Moment', description: 'The best time to ask for a review is the second your client sees their new look in the mirror. Your elegant Salon branded QR codes will capture your clients "after-color glow" before they even reach for their purse.', icon: 'tabler:sparkles' },
        { title: 'Local Search SEO', description: 'When someone searches "best hair colorist near me," Google looks for three things: Star rating, review frequency, and recency. We automate all three.', icon: 'tabler:map-pin' },
        { title: 'Client Retention', description: 'A client who leaves a 5-star review is 40% more likely to re-book. Our system turns a one-time walk-in into a lifelong brand advocate.', icon: 'tabler:users' },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Why your salon needs <span class="text-accent">Reviews on Autopilot ⭐⭐⭐⭐⭐</span>
      </h3>
      <p>Clients look at screens, not storefronts. In this modern age, your reviews are your digital handshake—we make sure yours is a 5-star introduction.</p>
    </Fragment>
    <Fragment slot="image">
       <img src="/images/testimonial-4.webp" alt="Happy salon client after service" class="rounded-lg shadow-xl w-full" />
    </Fragment>
  </Content>

  <!-- Content 2: The Commitment (Industry Empathy) -->
  <Content
    items={[
      { title: 'Zero Maintenance', description: 'We know you’re busy with back-to-back bookings. Once we set up your system, you never have to log in or "manage" anything.', icon: 'tabler:settings' },
      { title: 'The "Wall of Love" Widget', description: 'We automatically sync and showcase your best reviews on your website, building instant trust with new visitors 24/7.', icon: 'tabler:stars' },
      { title: 'One-Time Payment', description: 'We don’t believe in monthly fees that eat your profits. $99 once, and you own the system for the life of your salon.', icon: 'tabler:coin' },
    ]}
  >
    <Fragment slot="content">
      <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
        Our Commitment to Your Success
      </h2>
      <p class="text-xl text-muted dark:text-slate-400 mb-8">
        We aren't just another software company. We are a partner in your growth. We handle the Google integrations and the technical hurdles so you can stay focused on your art.
      </p>
    </Fragment>
    <Fragment slot="image">
      <!-- Use a different image here to show the "Business/Tech" side of the salon -->
      <img 
        src="/images/testimonial-3.webp" 
        alt="Salon professional looking at positive feedback" 
        class="rounded-lg shadow-xl w-full"
      />
    </Fragment>
  </Content>

  <Pricing
    class="pb-0"
    title={`<span class="text-accent dark:text-white">Invest in Your Salon’s Future.</span>`}
    prices={[lifetimeDeal]}
  />

  <!-- Final Visual: "The End Result" -->
  <Hero class="-mt-16">
    <Fragment slot="image">
      <img 
        src="/images/testimonial-6.webp" 
        alt="A wall of 5-star salon reviews" 
        class="mx-auto rounded-md w-full shadow-lg"
        loading="lazy"
      />
    </Fragment>
  </Hero>

</Layout>
